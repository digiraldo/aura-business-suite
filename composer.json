{
  "name": "aura/business-suite",
  "description": "Suite modular de gestión empresarial para WordPress con sistema de permisos granulares",
  "version": "1.0.0",
  "type": "wordpress-plugin",
  "keywords": [
    "wordpress",
    "plugin",
    "business",
    "crm",
    "finance",
    "fleet-management",
    "iot",
    "electricity",
    "capabilities"
  ],
  "homepage": "https://github.com/yourusername/aura-business-suite",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Aura Development Team",
      "email": "dev@aurabusiness.com",
      "homepage": "https://aurabusiness.com"
    }
  ],
  "support": {
    "email": "soporte@aurabusiness.com",
    "issues": "https://github.com/yourusername/aura-business-suite/issues",
    "docs": "https://docs.aurabusiness.com"
  },
  "require": {
    "php": ">=8.0",
    "composer/installers": "~1.0",
    "mpdf/mpdf": "*",
    "phpoffice/phpspreadsheet": "^5.4"
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^3.7",
    "wp-coding-standards/wpcs": "^2.3",
    "phpunit/phpunit": "^9.5"
  },
  "autoload": {
    "psr-4": {
      "Aura\\BusinessSuite\\": "modules/"
    }
  },
  "scripts": {
    "phpcs": "phpcs --standard=WordPress --extensions=php --ignore=*/vendor/*,*/node_modules/* .",
    "phpcbf": "phpcbf --standard=WordPress --extensions=php --ignore=*/vendor/*,*/node_modules/* .",
    "test": "phpunit"
  },
  "extra": {
    "installer-name": "aura-business-suite"
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true,
    "allow-plugins": {
      "composer/installers": true
    }
  }
}
